{
  "permissions": {
    "allow": [
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(sqlite3:*)",
      "Bash(jq:*)",
      "Bash(awk:*)",
      "Bash(sed:*)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(pytest:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(mkdir:*)",
      "Bash(echo:*)",
      "Bash(for *)",
      "Bash(while *)",
      "Bash(pip list*)",
      "Bash(pip show*)",
      "Bash(nvidia-smi*)",
      "Bash(MAX_WALLCLOCK_SECONDS=120 torchrun*)"
    ],
    "ask": [
      "Bash(torchrun*)",
      "Bash(MAX_WALLCLOCK_SECONDS=600 torchrun*)",
      "Bash(PGOLF_CONFIRM_8XH100=1*)",
      "Bash(git push*)",
      "Bash(git reset*)",
      "Bash(git rebase*)",
      "Bash(rm*)",
      "Bash(pip install*)",
      "Bash(apt*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre-bash.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-bash.sh"
          }
        ]
      }
    ]
  }
}
